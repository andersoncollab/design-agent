# Design Agent — API Keys
# Copy to .env and fill in your keys

# Brandfetch — brand data (logos, colors, fonts, company info)
# Get your key at: https://brandfetch.com/developers
BRANDFETCH_API_KEY=

# remove.bg — background removal API (50 free calls/month)
# Get your key at: https://www.remove.bg/api
REMOVE_BG_API_KEY=
